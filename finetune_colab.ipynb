   "source": ["# ═══════ 8. Сохраняем LoRA ═══════\n", "model.save_pretrained(\"/content/qwen-coder-lora\")\n", "tokenizer.save_pretrained(\"/content/qwen-coder-lora\")\n", "print(\"✅ LoRA сохранена\")"],
